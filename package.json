{
  "name": "pi-feature-flow",
  "version": "0.2.0",
  "description": "Pi extension for feature-based ticket execution with persistent registry and next-ticket automation",
  "keywords": [
    "pi-package",
    "pi",
    "extension",
    "workflow",
    "tickets"
  ],
  "license": "MIT",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "yaml": "^2.8.1"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@marcfargas/pi-test-harness": "^0.5.0",
    "@mariozechner/pi-agent-core": "*",
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@playwright/test": "^1.59.1",
    "@types/node": "^24.6.0",
    "playwright": "^1.59.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "pi": {
    "extensions": [
      "./extensions/feature-ticket-flow.ts",
      "./extensions/feature-review-viewer.ts",
      "./extensions/feature-plan-viewer.ts",
      "./extensions/feature-ticket-viewer.ts"
    ],
    "skills": [
      "./skills"
    ],
    "prompts": [
      "./prompts"
    ]
  }
}
