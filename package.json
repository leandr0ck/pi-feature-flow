{
  "name": "pi-feature-flow",
  "version": "0.1.0",
  "description": "Pi extension for feature-based ticket execution with persistent registry and next-ticket automation",
  "keywords": ["pi-package", "pi", "extension", "workflow", "tickets"],
  "license": "MIT",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "pi-subagents": "^0.13.0",
    "yaml": "^2.8.1"
  },
  "bundledDependencies": [
    "pi-subagents"
  ],
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@marcfargas/pi-test-harness": "^0.5.0",
    "@mariozechner/pi-agent-core": "*",
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@types/node": "^24.6.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "pi": {
    "extensions": [
      "./extensions/feature-ticket-flow.ts",
      "./node_modules/pi-subagents/index.ts",
      "./node_modules/pi-subagents/notify.ts"
    ],
    "skills": ["./skills"],
    "prompts": ["./prompts"]
  }
}
